# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname
DIRECT_URL=postgresql://user:password@host/dbname

# Stripe (Production Keys)
STRIPE_SECRET_KEY=sk_live_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_key_here

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@pubmedpro.com

# Authentication
NEXTAUTH_SECRET=your_secret_key_here_min_32_chars
NEXTAUTH_URL=https://pubmedweb.vercel.app

# APIs
DEEPL_API_KEY=your_deepl_key
ANTHROPIC_API_KEY=your_claude_key
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

# Admin
ADMIN_TOKEN=your_admin_token_here
TERMINAL_TOKEN=your_terminal_token_here

# Environment
NODE_ENV=production
